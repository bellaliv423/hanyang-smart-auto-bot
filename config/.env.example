# ========================================
# Hanyang Smart Auto Bot - Environment Template
# 1. Copy: cp .env.example .env
# 2. Fill in your credentials below
# ========================================

# Hanyang Portal / HY-ON LMS
HANYANG_USER_ID=your_student_id
HANYANG_PASSWORD=your_password

# Claude API (for AI study assistant)
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# WhatsApp Notification (OpenClaw gateway, optional)
WHATSAPP_GATEWAY_URL=http://localhost:3000
WHATSAPP_TARGET=+82your_phone_number

# Notification preferences
REMINDER_BEFORE_CLASS_MINUTES=30
DAILY_SUMMARY_TIME=08:00
